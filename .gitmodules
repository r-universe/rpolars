[submodule ".registry"]
	path = .registry
	url = https://github.com/rpolars/universe
	shallow = true
	branch = HEAD
[submodule "rpolars"]
	path = rpolars
	url = https://github.com/pola-rs/r-polars
	shallow = true
	registered = true
[submodule "nanoarrow"]
	path = nanoarrow
	url = https://github.com/apache/arrow-nanoarrow
	shallow = true
	subdir = r
	registered = false
